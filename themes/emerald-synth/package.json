{
  "name": "slidev-theme-emerald-synth",
  "version": "0.0.0",
  "type": "module",
  "description": "A Slidev theme with synthwave/cyberpunk aesthetic from the Emerald Synth color palette",
  "keywords": [
    "slidev-theme",
    "slidev"
  ],
  "license": "MIT",
  "files": [
    "layouts",
    "styles",
    "setup",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "slidev build example.md",
    "dev": "slidev example.md --open",
    "export": "slidev export example.md",
    "screenshot": "slidev export example.md --format png"
  },
  "dependencies": {
    "@fontsource/monaspace-neon": "^5.2.5",
    "@fontsource/ibm-plex-sans-jp": "^5.2.8",
    "@slidev/types": "^52.14.1"
  },
  "devDependencies": {
    "@slidev/cli": "52.15.0",
    "playwright-chromium": "1.59.1"
  },
  "slidev": {
    "colorSchema": "dark",
    "highlighter": "shiki",
    "defaults": {
      "fonts": {
        "sans": "Monaspace Neon",
        "mono": "Monaspace Neon"
      }
    }
  }
}
