{
  "name": "Emerald Synth",
  "type": "dark",
  "colors": {
    "editor.background": "#0d0221",
    "editor.foreground": "#00ffcc"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6a5585",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#8b9cf7"
      }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": {
        "foreground": "#4dd0e1"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "scope": ["string.template", "punctuation.definition.string.template"],
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "scope": ["entity.name.type", "support.type", "support.class"],
      "settings": {
        "foreground": "#ffcc66"
      }
    },
    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#ffe099"
      }
    },
    {
      "scope": ["constant.language"],
      "settings": {
        "foreground": "#ffe099"
      }
    },
    {
      "scope": ["constant.other"],
      "settings": {
        "foreground": "#ffe099"
      }
    },
    {
      "scope": ["keyword.operator", "punctuation.accessor"],
      "settings": {
        "foreground": "#00ffcc"
      }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": {
        "foreground": "#00ffcc"
      }
    },
    {
      "scope": ["variable.other.property", "meta.property-name", "support.type.property-name"],
      "settings": {
        "foreground": "#4dd0e1"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#ff2a6d"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#4dd0e1"
      }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": {
        "foreground": "#6a5585"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#ff5c8a"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#8b9cf7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw"],
      "settings": {
        "foreground": "#4dd0e1"
      }
    }
  ]
}
