{
  "name": "slidev-theme-barrel",
  "version": "0.0.0",
  "type": "module",
  "description": "A Slidev theme with modern warm aesthetic — amber, cozy, refined",
  "keywords": [
    "slidev-theme",
    "slidev"
  ],
  "license": "MIT",
  "files": [
    "layouts",
    "styles",
    "setup",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "slidev build example.md",
    "dev": "slidev example.md --open",
    "export": "slidev export example.md",
    "screenshot": "slidev export example.md --format png"
  },
  "dependencies": {
    "@fontsource/libre-baskerville": "^5.2.10",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@slidev/types": "^52.14.1"
  },
  "devDependencies": {
    "@slidev/cli": "52.15.0",
    "playwright-chromium": "1.59.1"
  },
  "slidev": {
    "colorSchema": "dark",
    "highlighter": "shiki",
    "defaults": {
      "fonts": {
        "sans": "Inter",
        "serif": "Libre Baskerville",
        "mono": "Fira Code"
      }
    }
  }
}
