{
  "name": "Barrel",
  "type": "dark",
  "colors": {
    "editor.background": "#1c1816",
    "editor.foreground": "#e8ddd0"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7a6e62",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "keyword.control", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#6a9ec4"
      }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": {
        "foreground": "#e09f3e"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#7eb356"
      }
    },
    {
      "scope": ["string.template", "punctuation.definition.string.template"],
      "settings": {
        "foreground": "#7eb356"
      }
    },
    {
      "scope": ["entity.name.type", "support.type", "support.class"],
      "settings": {
        "foreground": "#d4890e"
      }
    },
    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#c47a5a"
      }
    },
    {
      "scope": ["constant.language"],
      "settings": {
        "foreground": "#c47a5a"
      }
    },
    {
      "scope": ["constant.other"],
      "settings": {
        "foreground": "#c47a5a"
      }
    },
    {
      "scope": ["keyword.operator", "punctuation.accessor"],
      "settings": {
        "foreground": "#c4b8a8"
      }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": {
        "foreground": "#e8ddd0"
      }
    },
    {
      "scope": ["variable.other.property", "meta.property-name", "support.type.property-name"],
      "settings": {
        "foreground": "#e09f3e"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#c45a4a"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#e09f3e"
      }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": {
        "foreground": "#7a6e62"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#c47a5a"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#e09f3e",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw"],
      "settings": {
        "foreground": "#6a9ec4"
      }
    }
  ]
}
